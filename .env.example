# Copy to `.env` before running.
#
# By default the take-home points at the local mock server.
# Swap to the real Parasail API by changing these two values.

# ----- Mock (default) -----
PARASAIL_BASE_URL=http://localhost:3001
PARASAIL_API_KEY=psk-mock-mockkey

# ----- Real -----
# The mock and the real API share endpoint suffixes (e.g. `/v1/models`,
# `/v1/chat/completions`). The real API serves them under `/api/v1/openai`,
# so absorbing that segment into the base URL means your client code
# doesn't have to change when you flip these two lines.
#
# PARASAIL_BASE_URL=https://api.parasail.io/api/v1/openai
# PARASAIL_API_KEY=psk-<accesskey>-<secretkey>

# ----- Mock-server tuning (optional) -----
# Min / max artificial latency in ms applied to every endpoint.
MOCK_LATENCY_MIN_MS=50
MOCK_LATENCY_MAX_MS=300

# Persist seed data + created entities across restarts.
# Leave unset for an in-memory (resets on restart) store.
# MOCK_PERSIST_PATH=/data/state.json
